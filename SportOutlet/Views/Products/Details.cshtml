@using SportOutlet.Data.Models
@model Product

<div class="container mt-4">

    <div class="row">

        <!-- 🖼️ IMAGES -->
        <div class="col-md-7">
            <div class="row">
                @foreach (var img in Model.ProductImages)
                {
                    <div class="col-md-6 mb-3">
                        <img src="@img.ImageUrl" class="img-fluid product-detail-img" />
                    </div>
                }
            </div>
        </div>

        <!-- 📦 INFO -->
        <div class="col-md-5">

            <p class="text-muted">@Model.SubCategory.Name</p>

            <h2 class="fw-bold">@Model.Name</h2>

            <h4 class="mt-3">@Model.Price лв</h4>

            <!-- 📏 SIZE -->
            <div class="mt-4">
                <h6>Изберете размер:</h6>

                @foreach (var variant in Model.ProductVariants)
                {
                    <button class="btn btn-outline-dark m-1 size-btn"
                            data-size="@variant.Size">
                        @variant.Size
                    </button>
                }
            </div>

            <!-- 🔢 QUANTITY -->
            <div class="mt-3 d-flex align-items-center">
                <button class="btn btn-outline-dark">-</button>
                <input type="text" value="1" class="form-control mx-2 text-center" style="width:60px;" />
                <button class="btn btn-outline-dark">+</button>
            </div>

            <!-- 🛒 ADD TO CART -->
            <div class="mt-3">
                <button class="btn btn-dark w-100">Добавете в количката</button>
            </div>

        </div>
    </div>

    <!-- 🔥 OUTFITS -->
    <div class="mt-5">
        <h3 class="mb-3">Завършете визията</h3>

        <div class="row">
            @foreach (var item in ViewBag.Outfits)
            {
                <div class="col-md-3 mb-4">
                    <a href="/Products/Details/@item.Id">
                        <img src="@item.ProductImages.FirstOrDefault()?.ImageUrl"
                             class="img-fluid product-card-img" />
                    </a>
                    <p class="mt-2">@item.Name</p>
                </div>
            }
        </div>
    </div>

    <!-- 🔥 SIMILAR -->
    <div class="mt-5">
        <h3 class="mb-3">Подобни продукти</h3>

        <div class="row">
            @foreach (var item in ViewBag.SimilarProducts)
            {
                <div class="col-md-3 mb-4">
                    <a href="/Products/Details/@item.Id">
                        <img src="@item.ProductImages.FirstOrDefault()?.ImageUrl"
                             class="img-fluid product-card-img" />
                    </a>
                    <p class="mt-2">@item.Name</p>
                </div>
            }
        </div>
    </div>

</div>
